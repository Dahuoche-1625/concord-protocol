{
  "task_id": "{{TASK_ID}}",
  "task_mode": "bridge",
  "project_id": "{{PROJECT_ID}}",
  "application_id": "{{APPLICATION_ID}}",
  "required_protocol_version": "0.2",
  "required_capabilities": ["{{REQUIRED_CAPABILITY}}"],
  "output_contract_ref": "{{OUTPUT_CONTRACT_REF}}",
  "context_scope": "task_only",
  "context_expires_at": "{{CONTEXT_EXPIRES_AT_ISO8601}}",
  "input_refs": [
    "project://deployment_manifest.local.json",
    "project://{{TASK_INPUT_REF}}"
  ],
  "redactions": [
    "oauth_token",
    "client_secret",
    "full_channel_registry",
    "full_project_memory"
  ],
  "dispatch_policy": "capability_match",
  "target_mesh": "{{TARGET_MESH_ID}}",
  "assigned_agent": null,
  "risk_level": "low",
  "timeout_sec": 1800,
  "acceptance_criteria": [
    "final artifact exists",
    "artifact_refs include size_bytes and sha256",
    "log_refs include pipeline log",
    "RuntimeGuard guarded_verify result is pass",
    "ReviewResult references this task receipt"
  ],
  "validation_script_ref": "{{VALIDATION_SCRIPT_REF}}",
  "contract_clarity_score": 4,
  "created_by": "{{PROJECT_AUTHORIZED_ISSUER}}",
  "created_at": "{{CREATED_AT_ISO8601}}",
  "source_refs": [
    "protocol/v0.2-pilot-plan.md",
    "examples/bridge_loop_pilot/acceptance_criteria.md"
  ],
  "source_proof": {
    "method": "hash_chain",
    "key_ref": "{{PROJECT_KEY_REF_OR_LOCAL_PLACEHOLDER}}",
    "signed_fields": [
      "task_id",
      "project_id",
      "required_capabilities",
      "input_refs",
      "acceptance_criteria"
    ],
    "value": "{{SOURCE_PROOF_VALUE}}"
  }
}
