{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-protocol.dev/schemas/capability_record.json",
  "title": "CapabilityRecord",
  "description": "Capability declaration for an agent. Must include verification evidence.",
  "type": "object",
  "required": ["agent_id", "capability", "verification", "status"],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "capability": {
      "type": "string",
      "description": "Capability name (e.g., 'code_execution', 'architecture_review').",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "verification": {
      "type": "object",
      "required": ["method", "evidence_refs"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["task_history", "manual_review", "dry_run", "test_result"]
        },
        "evidence_refs": {
          "type": "array",
          "description": "Must not be empty. Empty → confidence forced to low, status to probation.",
          "items": { "type": "string" },
          "minItems": 1
        },
        "last_verified_at": {
          "type": "string",
          "format": "date-time"
        },
        "verified_by": {
          "type": "string"
        }
      }
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "medium"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "probation", "restricted"],
      "description": "restricted agents cannot take risk_level:high tasks. Auto-downgraded after 3 consecutive violations."
    }
  }
}
